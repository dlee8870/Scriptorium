DATABASE_URL="postgresql://scriptorium:scriptorium@localhost:5433/scriptorium?schema=public"
SOURCE_DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN="1h"
BCRYPT_SALT_ROUNDS="10"
# Vercel Blob injects this value when a Blob store is connected.
BLOB_READ_WRITE_TOKEN=""

# Use "judge0" for the free hosted provider. Leave blank locally to use Docker.
EXECUTION_PROVIDER=""
JUDGE0_API_URL="https://ce.judge0.com"

# Optional self-hosted runner settings.
EXECUTION_API_URL=""
EXECUTION_API_KEY="replace-with-a-separate-random-secret"

# Runner-only settings.
RUNNER_API_KEY="replace-with-the-same-value-as-EXECUTION_API_KEY"
RUNNER_HOST="127.0.0.1"
RUNNER_PORT="4000"
